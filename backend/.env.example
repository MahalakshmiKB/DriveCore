# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CLIENT_ORIGIN=http://localhost:5173

# ── Database (MySQL via Prisma) ─────────────────────────
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/drivecore"

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=drivecore_rt

# ── Bcrypt ────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Rate limiting ─────────────────────────────────────
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ── Nodemailer (SMTP) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="DriveCore <no-reply@drivecore.app>"

# ── Password reset ────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRES_MIN=30
PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
